# Cloudflare API Configuration
# 获取方式：登录 Cloudflare 控制台 -> My Profile -> API Tokens
# 注意：生产环境已迁移到 Cloudflare Workers，本地开发保留
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# SUPABASE Configuration
# 获取方式：登录 Supabase 控制台 -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUB_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# API Keys (可选，用于测试)
# API_KEY=sk_your_test_api_key_here

# Workers Chat Server (生产环境)
CHAT_SERVER_URL=https://chatapi.rertx.dpdns.org

# Internal Chat Secret (仅用于本地开发，生产环境使用 Workers Secrets)
# 建议在生产环境使用更复杂的随机字符串
INTERNAL_CHAT_SECRET=your-internal-secret-key-change-in-production
NEXT_PUBLIC_INTERNAL_CHAT_SECRET=your-internal-secret-key-change-in-production
