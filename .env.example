# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# SUPABASE Configuration
# 获取方式：登录 Supabase 控制台 -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUB_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Workers Chat Server (生产环境)
CHAT_SERVER_URL=https://chatapi.rertx.dpdns.org

# Internal Chat Secret
INTERNAL_CHAT_SECRET=your-internal-secret-key-change-in-production